# Apple CalDAV
APPLE_CALDAV_URL=https://caldav.icloud.com
APPLE_USERNAME=your_apple_id@example.com
APPLE_APP_PASSWORD=app-specific-password
APPLE_CALENDAR_URLS=https://caldav.icloud.com/1234567890/calendars/work/,https://caldav.icloud.com/1234567890/calendars/personal/

# Google service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\\nABC...\\n-----END PRIVATE KEY-----\\n"
GOOGLE_CALENDAR_IDS=primary,team@example.com

# Runtime
SYNC_INTERVAL_MINUTES=5
SYNC_WINDOW_DAYS=180
TZ=UTC
LOG_LEVEL=info
